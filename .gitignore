# ── Dependencies ─────────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# ── Environment variables (NEVER commit secrets) ─────────────
.env
.env.local
.env.development
.env.production
.env.staging
# Keep example files so new devs know what vars are needed
!.env.example
!.env.local.example

# ── Backend build output ──────────────────────────────────────
backend/dist/
backend/build/
backend/coverage/

# ── Next.js build output ─────────────────────────────────────
frontend/.next/
frontend/out/
frontend/build/
frontend/coverage/
frontend/next-env.d.ts

# ── Logs ─────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
/tmp/*.log

# ── TypeScript cache ─────────────────────────────────────────
*.tsbuildinfo

# ── OS generated files ───────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ── IDE / editor ─────────────────────────────────────────────
.vscode/
!.vscode/extensions.json
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~

# ── File uploads (user-generated, not for git) ───────────────
backend/uploads/
public/uploads/

# ── Test & coverage ──────────────────────────────────────────
coverage/
.nyc_output/
test-results/
playwright-report/
cypress/videos/
cypress/screenshots/

# ── Misc ─────────────────────────────────────────────────────
*.pem
*.key
*.cert
.cache/
.parcel-cache/
.turbo/
